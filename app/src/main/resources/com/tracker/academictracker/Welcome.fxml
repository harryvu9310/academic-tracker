<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>

<ScrollPane fitToWidth="true" hbarPolicy="NEVER" pannable="true" styleClass="page-scroll" vbarPolicy="AS_NEEDED" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.tracker.academictracker.controller.WelcomeController">
<content>
<VBox alignment="CENTER" minHeight="620.0" styleClass="welcome-page">
    <VBox alignment="TOP_CENTER" maxWidth="470.0" spacing="18.0" styleClass="glass-card">
        <padding>
            <Insets bottom="42.0" left="42.0" right="42.0" top="42.0" />
        </padding>
        <Label styleClass="page-title" text="Academic Tracker" />
        <Label styleClass="page-subtitle" text="Set up your local academic command center." wrapText="true" />

        <VBox spacing="14.0">
            <VBox spacing="6.0">
                <Label styleClass="form-label" text="Full Name" />
                <TextField fx:id="nameInput" promptText="e.g., Nguyen Van A" />
            </VBox>
            <VBox spacing="6.0">
                <Label styleClass="form-label" text="Student ID" />
                <TextField fx:id="idInput" promptText="e.g., SE123456" />
            </VBox>
        </VBox>

        <Label fx:id="errorLabel" styleClass="validation-message" text="" />
        <Button maxWidth="Infinity" mnemonicParsing="false" onAction="#handleCreateProfile" styleClass="primary-button" text="Create Profile &amp; Continue" />
    </VBox>
</VBox>
</content>
</ScrollPane>
