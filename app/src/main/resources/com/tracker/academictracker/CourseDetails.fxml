<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<ScrollPane fitToWidth="true" hbarPolicy="NEVER" pannable="true" styleClass="page-scroll" vbarPolicy="AS_NEEDED" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.tracker.academictracker.controller.CourseDetailsController">
<content>
<VBox spacing="22" styleClass="content-container">
    <HBox alignment="CENTER_LEFT" spacing="15">
        <VBox spacing="5">
            <Label styleClass="page-title" text="Course Details" />
            <Label styleClass="page-subtitle" text="Assessment structure, target score, feasibility, and risk." wrapText="true" />
        </VBox>
        <Region HBox.hgrow="ALWAYS" />
        <Button onAction="#handleBackToRoster" styleClass="secondary-button" text="Back to Courses" />
    </HBox>

    <FlowPane hgap="18" styleClass="responsive-flow" vgap="18">
        <VBox minWidth="320" spacing="14" styleClass="card">
            <HBox alignment="CENTER_LEFT" spacing="12">
                <VBox spacing="4">
                    <Label fx:id="courseCodeLabel" styleClass="section-caption" text="N/A" />
                    <Label fx:id="courseNameLabel" styleClass="section-title" text="Course Name" wrapText="true" />
                </VBox>
                <Region HBox.hgrow="ALWAYS" />
                <Label fx:id="statusLabel" styleClass="badge" text="Active" />
                <Label fx:id="majorLabel" styleClass="badge" text="General" />
            </HBox>
            <FlowPane hgap="28" styleClass="responsive-flow" vgap="14">
                <VBox minWidth="110" spacing="5">
                    <Label styleClass="metric-label" text="Credits" />
                    <Label fx:id="creditsLabel" styleClass="section-title" text="0" />
                </VBox>
                <VBox minWidth="180" spacing="5">
                    <Label styleClass="metric-label" text="Category" />
                    <Label fx:id="categoryLabel" styleClass="section-title" text="General" wrapText="true" />
                </VBox>
                <VBox minWidth="160" spacing="5">
                    <Label styleClass="metric-label" text="Current Grade" />
                    <Label fx:id="currentGradeLabel" styleClass="metric-value" text="N/A" />
                </VBox>
                <VBox minWidth="140" spacing="5">
                    <Label styleClass="metric-label" text="Total Weight" />
                    <Label fx:id="totalWeightLabel" styleClass="section-title" text="0%" />
                </VBox>
            </FlowPane>
        </VBox>
    </FlowPane>

    <VBox spacing="14" styleClass="settings-card">
        <Label styleClass="section-title" text="Add Assessment" />
        <FlowPane hgap="14" styleClass="responsive-flow" vgap="14">
            <VBox minWidth="240" prefWidth="360" spacing="6">
                <Label styleClass="form-label" text="Assessment Name" />
                <TextField fx:id="assessNameInput" promptText="e.g., Midterm Exam" />
            </VBox>
            <VBox minWidth="140" prefWidth="150" spacing="6">
                <Label styleClass="form-label" text="Category" />
                <ComboBox fx:id="categoryInput" maxWidth="Infinity" styleClass="modern-combo-box" />
            </VBox>
            <VBox minWidth="105" prefWidth="110" spacing="6">
                <Label styleClass="form-label" text="Weight (%)" />
                <TextField fx:id="weightInput" promptText="20" />
            </VBox>
            <VBox minWidth="105" prefWidth="110" spacing="6">
                <Label styleClass="form-label" text="Max Score" />
                <TextField fx:id="maxScoreInput" promptText="100" />
            </VBox>
            <VBox minWidth="105" prefWidth="110" spacing="6">
                <Label styleClass="form-label" text="Score" />
                <TextField fx:id="scoreInput" promptText="optional" />
            </VBox>
            <VBox alignment="BOTTOM_CENTER">
                <Button onAction="#saveAssessment" styleClass="primary-button" text="Add" />
            </VBox>
        </FlowPane>
    </VBox>

    <VBox spacing="14" styleClass="table-card" VBox.vgrow="ALWAYS">
        <HBox alignment="CENTER_LEFT">
            <Label styleClass="section-title" text="Assessments" />
            <Region HBox.hgrow="ALWAYS" />
            <Label styleClass="section-caption" text="Scores are converted to percentage contribution." />
        </HBox>
        <TableView fx:id="assessmentTable" minHeight="260" prefHeight="340" styleClass="modern-table">
            <columns>
                <TableColumn fx:id="colAssessName" minWidth="220.0" prefWidth="260.0" text="Assessment" />
                <TableColumn fx:id="colCategory" minWidth="140.0" prefWidth="160.0" text="Category" />
                <TableColumn fx:id="colWeight" minWidth="100.0" prefWidth="120.0" text="Weight" />
                <TableColumn fx:id="colScore" minWidth="140.0" prefWidth="160.0" text="Score" />
                <TableColumn fx:id="colAction" minWidth="160.0" prefWidth="180.0" text="Action" />
            </columns>
            <placeholder>
                <VBox alignment="CENTER" spacing="8">
                    <Label styleClass="section-title" text="No assessments yet" />
                    <Label styleClass="muted-text" text="Add assessments to calculate current pace and prediction." wrapText="true" />
                </VBox>
            </placeholder>
        </TableView>
    </VBox>

    <VBox spacing="14" styleClass="prediction-card">
        <FlowPane hgap="12" styleClass="responsive-flow" vgap="12">
            <VBox spacing="4">
                <Label styleClass="section-title" text="Course Target" />
                <Label styleClass="section-caption" text="Scenario estimate based on remaining weighted assessments." wrapText="true" />
            </VBox>
            <Region HBox.hgrow="ALWAYS" />
            <TextField fx:id="targetCourseGradeInput" onAction="#calculateCourseTarget" promptText="Goal % e.g., 85" prefWidth="160" />
            <Button onAction="#calculateCourseTarget" styleClass="primary-button" text="Predict" />
        </FlowPane>

        <FlowPane hgap="12" styleClass="responsive-flow" vgap="12">
            <VBox minWidth="180" prefWidth="210" spacing="5" styleClass="insight-card">
                <Label styleClass="metric-label" text="Required Remaining Average" />
                <Label fx:id="targetRequiredAverageLabel" styleClass="section-title" text="N/A" />
            </VBox>
            <VBox minWidth="160" prefWidth="190" spacing="5" styleClass="insight-card">
                <Label styleClass="metric-label" text="Feasibility" />
                <Label fx:id="targetFeasibilityLabel" styleClass="badge" text="No target" />
            </VBox>
            <VBox minWidth="140" prefWidth="170" spacing="5" styleClass="insight-card">
                <Label styleClass="metric-label" text="Risk" />
                <Label fx:id="targetRiskLabel" styleClass="badge" text="Unknown" />
            </VBox>
            <VBox minWidth="150" prefWidth="180" spacing="5" styleClass="insight-card">
                <Label styleClass="metric-label" text="Confidence" />
                <Label fx:id="targetConfidenceLabel" styleClass="badge" text="Unknown" />
            </VBox>
        </FlowPane>

        <Label fx:id="coursePredictionResultLabel" styleClass="body-text" text="Enter a target score to see required remaining average, feasibility, and risk." wrapText="true" />
    </VBox>
</VBox>
</content>
</ScrollPane>
