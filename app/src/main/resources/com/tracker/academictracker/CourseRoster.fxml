<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<ScrollPane fitToWidth="true" hbarPolicy="NEVER" pannable="true" styleClass="page-scroll" vbarPolicy="AS_NEEDED" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.tracker.academictracker.controller.CourseRosterController">
<content>
<VBox spacing="22" styleClass="content-container">
    <HBox alignment="CENTER_LEFT" spacing="15">
        <VBox spacing="5">
            <Label styleClass="page-title" text="Courses" />
            <Label styleClass="page-subtitle" text="Manage course status, credits, major classification, and current grade pace." wrapText="true" />
        </VBox>
        <Region HBox.hgrow="ALWAYS" />
        <Button onAction="#handleAddCourseClick" styleClass="primary-button" text="+ Add Course" />
    </HBox>

    <VBox fx:id="addCourseForm" managed="false" spacing="16" styleClass="settings-card" visible="false">
        <Label styleClass="section-title" text="Add New Course" />
        <FlowPane hgap="16" styleClass="responsive-flow" vgap="16">
            <VBox minWidth="220" prefWidth="320" spacing="6">
                <Label styleClass="form-label" text="Course Code" />
                <TextField fx:id="courseCodeInput" promptText="e.g., CS101" />
            </VBox>
            <VBox minWidth="260" prefWidth="420" spacing="6">
                <Label styleClass="form-label" text="Course Name" />
                <TextField fx:id="courseNameInput" promptText="e.g., Introduction to Programming" />
            </VBox>
        </FlowPane>

        <FlowPane hgap="16" styleClass="responsive-flow" vgap="16">
            <VBox minWidth="220" prefWidth="320" spacing="6">
                <Label styleClass="form-label" text="Category / Subject Group" />
                <TextField fx:id="categoryInput" promptText="e.g., Programming, Quantitative" />
            </VBox>
            <VBox minWidth="110" prefWidth="120" spacing="6">
                <Label styleClass="form-label" text="Credits" />
                <TextField fx:id="creditsInput" promptText="3" />
            </VBox>
            <VBox minWidth="160" prefWidth="170" spacing="6">
                <Label styleClass="form-label" text="Status" />
                <ComboBox fx:id="statusInput" maxWidth="Infinity" styleClass="modern-combo-box" />
            </VBox>
            <VBox alignment="CENTER_LEFT" minWidth="180" prefWidth="190" spacing="6">
                <Label styleClass="form-label" text="Major GPA" />
                <CheckBox fx:id="majorCourseInput" styleClass="modern-check-box" text="Counts as major" />
            </VBox>
        </FlowPane>

        <HBox spacing="10">
            <Button onAction="#saveNewCourse" styleClass="primary-button" text="Add Course" />
            <Button onAction="#hideAddForm" styleClass="secondary-button" text="Cancel" />
        </HBox>
    </VBox>

    <VBox spacing="14" styleClass="table-card" VBox.vgrow="ALWAYS">
        <FlowPane hgap="12" styleClass="responsive-flow" vgap="12">
            <TextField fx:id="searchInput" minWidth="260" prefWidth="420" promptText="Search course code, name, or category..." />
            <ComboBox fx:id="statusFilterInput" prefWidth="180" promptText="All statuses" styleClass="modern-combo-box" />
            <ComboBox fx:id="majorFilterInput" prefWidth="160" promptText="All courses" styleClass="modern-combo-box" />
        </FlowPane>

        <TableView fx:id="courseTable" minHeight="280" prefHeight="520" styleClass="modern-table">
            <columns>
                <TableColumn fx:id="colCode" minWidth="110.0" prefWidth="120.0" text="Course Code" />
                <TableColumn fx:id="colName" minWidth="220.0" prefWidth="270.0" text="Course Name" />
                <TableColumn fx:id="colCategory" minWidth="140.0" prefWidth="160.0" text="Category" />
                <TableColumn fx:id="colCredits" minWidth="80.0" prefWidth="90.0" text="Credits" />
                <TableColumn fx:id="colMajor" minWidth="110.0" prefWidth="120.0" text="Major" />
                <TableColumn fx:id="colStatus" minWidth="160.0" prefWidth="180.0" text="Status" />
                <TableColumn fx:id="colGrade" minWidth="120.0" prefWidth="140.0" text="Current Grade" />
                <TableColumn fx:id="colAction" minWidth="110.0" prefWidth="120.0" text="Actions" />
            </columns>
            <placeholder>
                <VBox alignment="CENTER" spacing="8">
                    <Label styleClass="section-title" text="No courses yet" />
                    <Label styleClass="muted-text" text="Start by adding your first course." wrapText="true" />
                </VBox>
            </placeholder>
        </TableView>
    </VBox>
</VBox>
</content>
</ScrollPane>
